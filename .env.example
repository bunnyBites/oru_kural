SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY        # publishable key — frontend and reads only
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY  # secret key — Python scripts (writes) only; never in frontend

GEMINI_API_KEY=YOUR_GEMINI_API_KEY
GEMINI_MODEL=gemini-2.5-flash

X_BEARER_TOKEN=YOUR_X_BEARER_TOKEN   # X API v2 app-only bearer token — get from developer.x.com
X_MAX_PAGES=1      # pages per run (default now 1 locally)
X_MAX_RESULTS=25   # tweets per page (10–100, default now 25)

# Reddit API (pending approval — use scrape_reddit.py JSON fallback until then)
# REDDIT_CLIENT_ID=        # Reddit app client ID — reddit.com/prefs/apps
# REDDIT_CLIENT_SECRET=    # Reddit app client secret
# REDDIT_USER_AGENT=       # e.g. "oru-kural/1.0 by u/yourusername"

PORT=3000
