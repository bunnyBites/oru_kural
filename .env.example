SUPABASE_URL=https://YOUR_SUPABASE_PROJECT_REF.supabase.co/rest/v1/
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY       # publishable key — frontend and reads only
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY  # secret key — Python scripts (writes) only; never in frontend

GEMINI_API_KEY=YOUR_GEMINI_API_KEY
GEMINI_MODEL=gemini-2.5-flash

APIFY_API_KEY=YOUR_APIFY_API_KEY

# Optional: set OPENROUTER_API_KEY to switch LLM provider without code changes
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=google/gemini-2.5-flash

# Direct Postgres connection from Supabase → Settings → Database → URI
# Must include ?sslmode=require
DATABASE_URL=postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres?sslmode=require

PORT=3000
