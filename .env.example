SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY        # publishable key — frontend and reads only
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY  # secret key — Python scripts (writes) only; never in frontend

GEMINI_API_KEY=YOUR_GEMINI_API_KEY
GEMINI_MODEL=gemini-2.5-flash

X_BEARER_TOKEN=YOUR_X_BEARER_TOKEN   # X API v2 app-only bearer token — get from developer.x.com

PORT=3000
